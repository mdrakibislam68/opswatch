# ─── Application ───────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production

# ─── Database ───────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=opswatch
DB_PASS=opswatch_secret
DB_NAME=opswatch

# ─── Redis ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ─── Frontend URL (CORS) ────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── SMTP (Email alerts) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ─── Telegram (Bot alerts) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCDEFxxxxxxxxxxxxxxxxxxxxxx
